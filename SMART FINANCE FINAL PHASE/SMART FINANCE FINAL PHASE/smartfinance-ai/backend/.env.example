# ─────────────────────────────────────────────────────────────────────────────
# SmartFinance AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/smartfinance
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/smartfinance
MONGODB_URI=mongodb://localhost:27017/smartfinance

# ── JWT (access token — short-lived) ─────────────────────────────────────────
JWT_SECRET=change_me_access_secret_min_32_chars
JWT_EXPIRES_IN=15m

# ── JWT (refresh token — long-lived) ─────────────────────────────────────────
REFRESH_TOKEN_SECRET=change_me_refresh_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Email / SMTP (overdue bill reminders — Phase 17) ──────────────────────────
# Gmail: enable App Passwords at myaccount.google.com/apppasswords
# Resend: host=smtp.resend.com port=465 user=resend pass=<api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@smartfinance.app
